# Model Registry Service Configuration

# Service
SERVICE_NAME=model-registry
DEBUG=True

# Database
DATABASE_URL=postgresql+asyncpg://meshml:meshml_password@localhost:5432/meshml

# Google Cloud Storage
GCS_BUCKET_NAME=meshml-models
GCS_PROJECT_ID=your-gcp-project-id
GCS_CREDENTIALS_PATH=/path/to/service-account-key.json

# Model Storage
MODEL_STORAGE_PREFIX=models
MAX_MODEL_SIZE_MB=100

# Search & Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Versioning
ENABLE_MODEL_VERSIONING=True
MAX_VERSION_HISTORY=10
