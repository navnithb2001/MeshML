# MeshML API Gateway - Environment Variables
# Copy this file to .env and fill in your values

# Environment
ENVIRONMENT=development
DEBUG=True

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql://meshml:meshml@localhost:5432/meshml

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=300

# Security
SECRET_KEY=change-this-to-a-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Rate Limiting
RATE_LIMIT_AUTHENTICATED=1000
RATE_LIMIT_UNAUTHENTICATED=100

# File Upload
MAX_UPLOAD_SIZE=104857600
UPLOAD_DIR=/tmp/meshml/uploads

# Google Cloud Storage
GCS_BUCKET_MODELS=meshml-models
GCS_BUCKET_DATASETS=meshml-datasets
GCS_BUCKET_ARTIFACTS=meshml-artifacts

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@meshml.dev

# Logging
LOG_LEVEL=INFO

# Workers
WORKER_HEARTBEAT_TIMEOUT=60

# Jobs
MAX_CONCURRENT_JOBS_PER_GROUP=10
JOB_TIMEOUT=86400
